{
  "manifest_version": 2,
  "name": "Container Tab Groups",
  "version": "0.1.0",
  "author": "Bruno Grillo Cruz",
  "description": "Automatically organize tabs into groups based on their Firefox Multi-Account Containers",
  "icons": {
    "48": "icons/icon-48.svg",
    "96": "icons/icon-96.svg"
  },
  "permissions": [
    "tabs",
    "tabGroups",
    "contextualIdentities",
    "storage"
  ],
  "background": {
    "scripts": ["background.js"],
    "persistent": true
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "browser_specific_settings": {
    "gecko": {
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  }
}
